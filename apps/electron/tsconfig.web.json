{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "types": ["vite/client"],
    "paths": {
      "@renderer/*": ["./src/renderer/*"]
    }
  },
  "include": ["src/renderer/**/*", "src/renderer/**/*.vue"]
}
