{
  "name": "openclaw-desktop",
  "version": "2026.3.10",
  "private": true,
  "description": "OpenClaw Desktop - Cross-platform management client",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/ensure-gateway-built.mjs && electron-vite dev",
    "build": "electron-vite build",
    "build:gateway": "node scripts/ensure-gateway-built.mjs",
    "bundle:gateway": "node scripts/bundle-gateway.mjs",
    "preview": "electron-vite preview",
    "package:mac": "pnpm bundle:gateway && electron-vite build && electron-builder --mac",
    "package:win": "pnpm bundle:gateway && electron-vite build && electron-builder --win",
    "package:linux": "pnpm bundle:gateway && electron-vite build && electron-builder --linux",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "naive-ui": "^2.40.3",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.3",
    "vue-router": "^4.5.0",
    "markdown-it": "^14.1.0",
    "@vicons/ionicons5": "^0.12.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vue-tsc": "^2.2.0",
    "@types/markdown-it": "^14.1.2"
  },
  "build": {
    "appId": "ai.openclaw.desktop",
    "productName": "OpenClaw Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "!resources/gateway/**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/gateway",
        "to": "gateway",
        "filter": ["**/*", "!**/*.map"]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "resources/icon.png",
      "category": "Development"
    }
  }
}
